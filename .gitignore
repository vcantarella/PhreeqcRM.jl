# Local libphreeqcrm build (Phase 0) — rebuilt locally / in CI
deps/src/
deps/build/
deps/usr/

# Julia package state
Manifest.toml
*.cov
coverage/
*.jl.cov
*.jl.mem

# Documenter build output
docs/build/
docs/site/

# Benchmark run artifacts (per-run; baselines under benchmark/baseline/ ARE committed)
benchmark/latest.json
benchmark/c_timings.json
benchmark/c_vs_julia.json
benchmark/judge_*.json
benchmark/judge_summary.md
benchmark/plots/

# Test harness outputs
test/results.json
test/c_build/*_driver
test/c_build/generic_driver
test/c_build/*.o
test/reference_suite/*/c_driver.sel
test/reference_suite/*/julia_driver.sel
test/reference_suite/*/*.out

# PHREEQC scratch output (generated by RunFile when output is enabled)
*.chem.txt
*.log.txt
*.sel
!test/reference_suite/*/reference/*.sel

# Papers / non-code artifacts kept locally but not pushed
*.pdf

# macOS / editor noise
.DS_Store
.vscode/
.idea/
*.swp
